generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // מותאם לעבודה בענן (Vercel + Fly.io)
  url      = env("DATABASE_URL")
}

// ==========================================
// הגדרות מערכת, ניתוב וסטטוס בוט
// ==========================================

model SystemSettings {
  id               String   @id @default("global")
  forwardingNumber String   @default("972501234567") // המספר שאליו הבוט ישלח את הלידים החמים
  qrCode           String?  @db.Text                 // הברקוד שהבוט מייצר ב-Fly.io ונשמר כדי שהפאנל יציג אותו
  botStatus        String   @default("DISCONNECTED") // מצב חיבור הבוט: WAITING_QR, CONNECTED, DISCONNECTED
  updatedAt        DateTime @updatedAt
}

model Lead {
  id          String   @id @default(cuid())
  name        String   @default("לקוח פוטנציאלי")
  phone       String   @unique
  serviceType String?
  budget      String?                                  // שדה התקציב לסינון ותעדוף לידים (Lead Scoring)
  status      String   @default("NEW")
  botState    String   @default("INITIAL")
  createdAt   DateTime @default(now())
}

// ==========================================
// ניהול תוכן, חבילות ותיק עבודות דינמי
// ==========================================

// טבלת חבילות דינמיות - לשליטה מלאה על מחירים מפאנל האדמין
model Package {
  id          String   @id @default(cuid())
  page        String   // מזהה באיזה עמוד להציג: 'home', 'web', 'marketing', 'automations'
  title       String   // שם החבילה (לדוגמה: Business Identity)
  price       String   // מחיר (לדוגמה: החל מ-₪3,500)
  description String   // תיאור החבילה
  features    String   // הפיצ'רים בחבילה (טקסט מופרד בפסיקים)
  isGold      Boolean  @default(false) // חבילת Premium מודגשת (זהב)
  createdAt   DateTime @default(now())
}

// דוגמאות לעבודות בגלריה
model Portfolio {
  id        String   @id @default(cuid())
  title     String
  category  String   // שיוך קטגוריה: 'web', 'marketing', 'automations'
  imageUrl  String   // כתובת ה-URL של התמונה
  link      String?  // קישור חיצוני לצפייה בפרויקט (אופציונלי)
  createdAt DateTime @default(now())
}

// לקוחות ממליצים
model Testimonial {
  id        String   @id @default(cuid())
  author    String
  role      String
  text      String   // תוכן ההמלצה
  createdAt DateTime @default(now())
}

// לוגואים של חברות (Trusted By)
model ClientLogo {
  id        String   @id @default(cuid())
  name      String   // שם החברה
  imageUrl  String   // URL של הלוגו
  createdAt DateTime @default(now())
}