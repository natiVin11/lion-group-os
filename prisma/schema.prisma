generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// הגדרות מערכת, ניתוב וסטטוס בוט
// ==========================================

model SystemSettings {
  id               String   @id @default("global")
  forwardingNumber String   @default("972501234567")
  qrCode           String?  @db.Text
  botStatus        String   @default("DISCONNECTED")
  updatedAt        DateTime @updatedAt
}

model Lead {
  id          String   @id @default(cuid())
  name        String   @default("לקוח פוטנציאלי")
  phone       String   @unique
  serviceType String?
  budget      String?
  status      String   @default("NEW")
  botState    String   @default("INITIAL")
  createdAt   DateTime @default(now())
}

// ==========================================
// ניהול תוכן, קטגוריות וחבילות
// ==========================================

// טבלה חדשה להגדרת קטגוריות (זה מה שהיה חסר!)
model Category {
  id         String      @id @default(cuid())
  name       String
  slug       String      @unique // הקטגוריה נשלפת לפי ה-slug הזה
  portfolios Portfolio[] // קשר: לקטגוריה יש הרבה פרויקטים
  createdAt  DateTime    @default(now())
}

model Package {
  id          String   @id @default(cuid())
  page        String
  title       String
  price       String
  description String
  features    String
  isGold      Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Portfolio {
  id         String    @id @default(cuid())
  title      String
  imageUrl   String
  link       String?
  createdAt  DateTime  @default(now())

  // שיוך לקטגוריה
  categoryId String
  category   Category  @relation(fields: [categoryId], references: [id])
}

model Testimonial {
  id        String   @id @default(cuid())
  author    String
  role      String
  text      String
  createdAt DateTime @default(now())
}

model ClientLogo {
  id        String   @id @default(cuid())
  name      String
  imageUrl  String
  createdAt DateTime @default(now())
}